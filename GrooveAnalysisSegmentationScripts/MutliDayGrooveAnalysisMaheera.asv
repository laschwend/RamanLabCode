%% functions

%from claude haiku 4.5 to get average plots across conditions
function [x, mean_y, std_y_upper, std_y_lower] = plotPopulationGrooveAverage(grooveObjects)
    % Takes a cell array of groove objects and outputs population statistics
    % using pooled standard deviation across all objects
    % Inputs:
    %   grooveObjects: cell array of objects with .Grooves property
    % Outputs:
    %   x: x-axis values
    %   mean_y: population mean
    %   std_y_upper: upper standard deviation bound
    %   std_y_lower: lower standard deviation bound
    
    numObjects = length(grooveObjects);
    
    % Get reference x-axis from first object
    firstObj = grooveObjects{1};
    firstAverage = mean(firstObj.Grooves, 3);
    x = firstObj.Grooves(:, 1, 1);
    xLength = length(x);
    
    % Initialize arrays to store means and stds from each object
    objectMeans = [];
    objectStds = [];
    
    % Calculate mean and std for each object
    for i = 1:numObjects
        obj = grooveObjects{i};
        grooves = obj.Grooves; % [nPoints, 2, nGrooves]
        
        % Calculate average and std within this object
        objAverage = mean(grooves, 3);
        objMean = objAverage(:, 2);
        objStd = std(grooves(:, 2, :), [], 3);
        
        objectMeans = [objectMeans, objMean];
        objectStds = [objectStds, objStd];
    end
    
    % Calculate population mean across all objects
    mean_y = mean(objectMeans, 2);
    
    % Calculate pooled standard deviation
    % sqrt(sum(s_i^2) / n)
    pooledVariance = sum(objectStds.^2, 2) / numObjects;
    std_y = sqrt(pooledVariance);
    
    std_y_upper = mean_y + std_y;
    std_y_lower = mean_y - std_y;
end

function [p] = plotGrooveAverage(x,mean_y,std_y_upper,std_y_lower, color)
    
  
   p = plot(x, mean_y, '-', 'LineWidth', 2, 'Color',color);
    % plot(x, std_y_upper, '--');
    % plot(x, std_y_lower, '--');
    patch([x; flip(x)], [std_y_lower; flip(std_y_upper)], [1 1 1]*0.8, 'FaceAlpha', 0.5, 'EdgeColor', 'none', 'FaceColor', color);

end

function []
