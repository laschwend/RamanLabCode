%% Summary analysis - grooves over time for each condition

plotConditions = {"G5", "G7pt5", "G10", "Fibrin"};
legendConditions = {"D0", "D2", "D4", "D6"};
colors = ["#c4a69d","#98a886","#465c69","#363457","#735290"];
numPlots = size(plotConditions,2);
figure(); 
for i = 1:numPlots
    subplot(1,numPlots, i);
    Condition = plotConditions{i};
    hold on; 
    pHandles = [];
    %add the average to the legend
    for j = 1:size(legendConditions, 2)
        legendCond = legendConditions{j};
        %first get a list of all of the relevant indices of groove objects
        idx = find(cellfun(@(x) x == legendCond, dayLabel) & cellfun(@(x) x == Condition, GelLabel));

        [x,mean_y, stdUp, stdLow] = plotPopulationGrooveAverage({Data{idx}});

       pHandles(end+1) = plotGrooveAverage(x,mean_y, stdUp, stdLow, colors(j));

    end

    %plot nominal graph

    title(Condition)
    legend(pHandles, legendConditions)
end


